{
  "name": "@expense-tracker-ui/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx serve",
    "build": "nx build",
    "test:coverage": "nx  run-many --all --target=test --codeCoverage=true --skip-nx-cache --output-style=static --coverageReporters='json,lcov,text,clover'",
    "coverage:aggregate": "istanbul report --dir coverage --include coverage/**/coverage-final.json lcov --skip-nx-cache",
    "coverage:all": "npm run test:coverage && npm run coverage:aggregate",
    "test:all": "nx run-many --all --target=test --configuration=ci",
    "lint:all": "nx run-many --all --target=lint",
    "build:stats": "nx build --stats-json",
    "analyze:ui": "webpack-bundle-analyzer dist/expense-tracker-ui/stats.json",
    "generate:api": "cross-env OPENAPI_PATH=${OPENAPI_PATH:../expense-tracker-parent/expense-tracker-core/openapi.json} openapi-generator-cli generate -i $OPENAPI_PATH -g typescript-angular -o ./libs/shared/api/src/lib/generated --additional-properties=stringEnums=true",
    "e2e": "nx e2e e2e --watch",
    "sonar": "sonar-scanner"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.4",
